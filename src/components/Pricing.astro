---
// src/components/Pricing.astro
// Sección de módulos de hardware (CapEx) y suscripción SaaS (OpEx)

const plans = [
  {
    id: 'plan-basic',
    level: 'Nivel Básico',
    subtitle: 'Meteo Esencial',
    price: '450€ – 600€',
    priceNote: 'instalación incluida',
    featured: false,
    badge: null,
    profile: 'Sustituto de estaciones genéricas.',
    includes: [
      'Hub Central LoRa',
      'Nodo Termo-higrómetro',
      'Pluviómetro ultrasónico',
      'App móvil básica',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>`,
  },
  {
    id: 'plan-advanced',
    level: 'Nivel Avanzado',
    subtitle: 'Suelo & Ciclo Hídrico',
    price: '1.200€ – 1.800€',
    priceNote: 'según superficie',
    featured: true,
    badge: 'Más Popular',
    profile: 'Gestión hídrica y de suelo integrada.',
    includes: [
      'Todo lo del Nivel Básico',
      'Sondas de humedad multicapa',
      'Sensor de pH y conductividad',
      'Caudalímetros de riego',
      'Alertas de estrés hídrico',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`,
  },
  {
    id: 'plan-premium',
    level: 'Nivel Premium',
    subtitle: 'Control Total',
    price: 'Desde 2.500€',
    priceNote: 'diseño personalizado',
    featured: false,
    badge: null,
    profile: 'Explotaciones de alta tecnificación.',
    includes: [
      'Todo lo del Nivel Avanzado',
      'Sensores NPK de suelo',
      'Actuadores de riego remotos',
      'Sensor de Radiación PAR',
      'Integración con maquinaria',
    ],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
];
---

<section
  id="precios"
  class="bg-white py-24 px-6"
  aria-labelledby="pricing-heading"
>
  <div class="max-w-6xl mx-auto">

    <!-- Encabezado -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-brand-primary font-semibold text-xs tracking-widest uppercase mb-3">
        Modelos & Precios
      </p>
      <h2
        id="pricing-heading"
        class="text-3xl md:text-4xl font-bold font-display text-brand-dark leading-tight"
      >
        Tecnología que crece con tu terreno
      </h2>
      <p class="text-slate-500 mt-4 leading-relaxed">
        Paga solo por el hardware que necesitas. Escalabilidad modular sin límites.
      </p>
    </div>

    <!-- Grid de tarjetas -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {plans.map((plan) => (
        <article
          id={plan.id}
          class={[
            'relative flex flex-col rounded-3xl p-8 border transition-all duration-300 hover:shadow-xl',
            plan.featured
              ? 'border-brand-primary bg-eco-bg shadow-medium ring-2 ring-brand-primary/20'
              : 'border-slate-100 bg-eco-bg hover:border-brand-primary/30',
          ].join(' ')}
          aria-label={`Plan ${plan.level}`}
        >
          <!-- Badge "Más Popular" -->
          {plan.badge && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center px-4 py-1 bg-brand-primary text-white text-xs font-bold rounded-full shadow-soft">
                ★ {plan.badge}
              </span>
            </div>
          )}

          <!-- Icono + nivel -->
          <div class="flex items-center gap-3 mb-6">
            <div class={[
              'w-11 h-11 flex items-center justify-center rounded-xl',
              plan.featured ? 'bg-brand-primary text-white' : 'bg-brand-light text-brand-primary',
            ].join(' ')}>
              <Fragment set:html={plan.icon} />
            </div>
            <div>
              <p class="text-xs font-semibold text-brand-primary uppercase tracking-wider">
                {plan.subtitle}
              </p>
              <h3 class="text-lg font-bold text-brand-dark leading-tight">
                {plan.level}
              </h3>
            </div>
          </div>

          <!-- Precio -->
          <div class="mb-1">
            <span class={[
              'text-3xl font-bold leading-none',
              plan.featured ? 'text-brand-dark' : 'text-brand-dark',
            ].join(' ')}>
              {plan.price}
            </span>
          </div>
          <p class="text-xs text-slate-400 mb-6">{plan.priceNote}</p>

          <!-- Perfil -->
          <p class="text-sm text-slate-500 italic mb-6 pb-6 border-b border-slate-100">
            {plan.profile}
          </p>

          <!-- Lista de includes -->
          <ul class="flex flex-col gap-3 mb-8 flex-grow" role="list" aria-label={`Incluye en ${plan.level}`}>
            {plan.includes.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-600">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-4 h-4 mt-0.5 flex-shrink-0 text-brand-primary"
                  aria-hidden="true"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="/contacto"
            id={`pricing-cta-${plan.id}`}
            class={[
              'w-full text-center py-3 rounded-xl text-sm font-semibold transition-all duration-200',
              plan.featured
                ? 'bg-brand-primary text-white hover:bg-green-500 shadow-soft hover:shadow-medium'
                : 'border-2 border-brand-dark text-brand-dark hover:bg-brand-dark hover:text-white',
            ].join(' ')}
            aria-label={`Solicitar información sobre el plan ${plan.level}`}
          >
            Solicitar información
          </a>
        </article>
      ))}
    </div>

    <!-- Banner SaaS -->
    <div
      class="bg-brand-light rounded-2xl p-6 mt-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 border border-green-200"
      role="region"
      aria-label="Suscripción SaaS mensual"
    >
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-xl bg-brand-primary/10 text-brand-primary mt-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
            <path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-brand-dark">Suscripción Base de Datos (SaaS)</p>
          <p class="text-sm text-slate-600 mt-0.5 max-w-xl">
            Incluye plataforma unificada, alertas móviles en tiempo real, almacenamiento histórico
            ilimitado y actualizaciones de firmware automáticas.
          </p>
        </div>
      </div>
      <div class="flex flex-col items-start md:items-end gap-1 flex-shrink-0">
        <span class="text-2xl font-bold text-brand-dark">15€ <span class="text-base font-normal text-slate-500">/ mes</span></span>
        <span class="text-xs text-slate-400">por hub · sin permanencia</span>
      </div>
    </div>

  </div>
</section>
