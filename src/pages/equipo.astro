---
// src/pages/equipo.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Equipo — LoRaTerra"
  description="El equipo multidisciplinar de LoRaTerra: ingenieros de telecomunicaciones, agrónomos y expertos en datos trabajando por una agricultura de precisión."
>
  <div class="pt-32 pb-20 px-6 bg-eco-bg min-h-screen">
    <div class="max-w-7xl mx-auto">
      <p class="text-brand-primary font-semibold text-sm tracking-wide uppercase mb-3">Equipo</p>
      <h1 class="text-4xl md:text-5xl font-bold font-display text-brand-dark leading-tight max-w-2xl">
        Ingenieros y agrónomos apasionados
      </h1>
      <p class="text-slate-600 mt-6 max-w-xl leading-relaxed text-lg">
        Conoce al equipo multidisciplinar detrás de LoRaTerra, combinando agronomía, electrónica IoT
        e ingeniería de datos.
        <em class="not-italic font-semibold text-brand-dark">Próximamente.</em>
      </p>
    </div>
  </div>
</Layout>
