---
// src/pages/impacto.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Impacto & Precios — LoRaTerra"
  description="Resultados reales en el campo: ahorro hídrico del 25%, reducción de pérdidas del 40% y ROI comprobado para cooperativas agrícolas y consorcios."
>
  <div class="pt-32 pb-20 px-6 bg-eco-bg min-h-screen">
    <div class="max-w-7xl mx-auto">
      <p class="text-brand-primary font-semibold text-sm tracking-wide uppercase mb-3">Impacto & Precios</p>
      <h1 class="text-4xl md:text-5xl font-bold font-display text-brand-dark leading-tight max-w-2xl">
        Resultados reales en el campo
      </h1>
      <p class="text-slate-600 mt-6 max-w-xl leading-relaxed text-lg">
        Métricas de ahorro hídrico, ROI verificado y planes de acceso para cooperativas y consorcios agrícolas.
        <em class="not-italic font-semibold text-brand-dark">Próximamente.</em>
      </p>
    </div>
  </div>
</Layout>
